# Copy this file to .env and fill in the required values before running the application.
# Required variables have no default and must be set explicitly.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=mydb
DB_MAX_CONNECTIONS=10

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
API_BASE_URL=http://localhost:8080

# ── TLS (required) ────────────────────────────────────────────────────────────
TLS_CERT_PATH=/path/to/cert.pem

# ── Auth ──────────────────────────────────────────────────────────────────────
# AUTH_SECRET is required — replace with a random string of at least 32 characters.
AUTH_SECRET=change-me-to-a-secure-random-secret-at-least-32-chars
TOKEN_EXPIRY_SECONDS=3600

# ── OAuth2 (optional — leave blank to disable OAuth2 login) ───────────────────
OAUTH_CLIENT_ID=
OAUTH_REDIRECT_URI=https://myapp.example.com/oauth/callback

# ── Feature flags ─────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=300
FEATURE_FLAG_HOST=flags.example.com
